# ---------------------------------------------------------------------------
# Zippy configuration. Copy to `.env.local` and fill in.
# ---------------------------------------------------------------------------

# EVE Online SSO (register an application at https://developers.eveonline.com/)
#   - Connection type: "Authentication & API Access"
#   - Scopes: esi-location.read_location.v1, esi-ui.write_waypoint.v1
#   - Callback URL: http://localhost:3000/api/auth/callback
EVE_CLIENT_ID=
EVE_CLIENT_SECRET=
EVE_CALLBACK_URL=http://localhost:3000/api/auth/callback

# Secret used to sign/verify Zippy's own session cookie (any long random string).
SESSION_SECRET=change-me-to-a-long-random-string

# Tripwire (optional — enables live wormhole connections)
# Base URL of the Tripwire instance you use.
TRIPWIRE_BASE_URL=https://tripwire.eve-apps.com
